@model DeliveryApp.Models.Order

@{
    ViewData["Title"] = "Create Order";
}

<h2 class ="text-center">Create Order</h2>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="FromCity">Город отправителя</label>
        <input asp-for="FromCity" class="form-control" />
        <span asp-validation-for="FromCity" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="FromAddress">Адрес отправителя</label>
        <input asp-for="FromAddress" class="form-control" />
        <span asp-validation-for="FromAddress" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ToCity">Город получателя</label>
        <input asp-for="ToCity" class="form-control" />
        <span asp-validation-for="ToCity" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ToAddress">Адрес получателя</label>
        <input asp-for="ToAddress" class="form-control" />
        <span asp-validation-for="ToAddress" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Weight">Вес груза</label>
        <input asp-for="Weight" class="form-control" />
        <span asp-validation-for="Weight" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="PickupDate">Дата забора груза</label>
        <input asp-for="PickupDate" class="form-control" type="date"/>
        <span asp-validation-for="PickupDate" class="text-danger"></span>
    </div>
    <input type="hidden" asp-for="OrderNumber" value="D-UNDIF" />
    <div class="form-group">
        <input type="submit" value="Создать" class="btn btn-primary" />
    </div>
</form>
